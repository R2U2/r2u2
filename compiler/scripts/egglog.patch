+    /// Collect root eclasses from the last let-bound variable.
+    pub fn collect_root_eclasses(&self) -> Vec<(ArcSort, Value)> {
+        let mut root_eclasses = Vec::new();
+        // Get the last let-bound variable (the final let expression in the program)
+        if let Some(var_name) = self.last_let_variable {
+            if let Some(function) = self.functions.get(&var_name) {
+                // Get the value if it exists
+                if let Some(value) = function.get(&[]) {
+                    root_eclasses.push((function.schema.output.clone(), value));
+                }
+            }
+        }
+        root_eclasses
+    }
