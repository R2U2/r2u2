(rewrite
  (Not (Not a0))
  a0
  :ruleset mltl-rewrites
)

(birewrite
  (Implies a0 a1)
  (Or2 (Not a0) a1)
  :ruleset mltl-rewrites
)

(birewrite
  (Equiv a0 a1)
  (And2 (Or2 (Not a0) a1) (Or2 (Not a1) a0))
  :ruleset mltl-rewrites
)

(birewrite
    (Not (And2 a0 a1))
    (Or2 (Not a0) (Not a1))
    :ruleset mltl-rewrites
)

(birewrite
  (Not (Or2 a0 a1))
  (And2 (Not a0) (Not a1))
  :ruleset mltl-rewrites
)