    (max (- (max wpd_a0 wpd_a1) bpd_a2) 0)
    (max (- (max wpd_a0 wpd_a2) bpd_a1) 0))
    (max (- (max wpd_a1 wpd_a2) bpd_a0) 0)
  )))
) :ruleset analysis)

(rule (
  (And4 a0 a1 a2 a3)
  (= wpd_a0 (wpd a0))
  (= wpd_a1 (wpd a1))
  (= wpd_a2 (wpd a2))
  (= wpd_a3 (wpd a3))
  (= bpd_a0 (bpd a0))
  (= bpd_a1 (bpd a1))
  (= bpd_a2 (bpd a2))
  (= bpd_a3 (bpd a3))
) (
  (set-cost (And4 a0 a1 a2 a3) 
  (+ 4 (+ (+ (+
    (max (- (max wpd_a0 (max wpd_a1 wpd_a2)) bpd_a3) 0)
    (max (- (max wpd_a0 (max wpd_a1 wpd_a3)) bpd_a2) 0))
    (max (- (max wpd_a0 (max wpd_a2 wpd_a3)) bpd_a1) 0))
    (max (- (max wpd_a1 (max wpd_a2 wpd_a3)) bpd_a0) 0)
  )))
) :ruleset analysis)

(rule (
  (Or4 a0 a1 a2 a3)
  (= wpd_a0 (wpd a0))
  (= wpd_a1 (wpd a1))
  (= wpd_a2 (wpd a2))
  (= wpd_a3 (wpd a3))
  (= bpd_a0 (bpd a0))
  (= bpd_a1 (bpd a1))
  (= bpd_a2 (bpd a2))
  (= bpd_a3 (bpd a3))
) (
  (set-cost (Or4 a0 a1 a2 a3) 
  (+ 4 (+ (+ (+
    (max (- (max wpd_a0 (max wpd_a1 wpd_a2)) bpd_a3) 0)
    (max (- (max wpd_a0 (max wpd_a1 wpd_a3)) bpd_a2) 0))
    (max (- (max wpd_a0 (max wpd_a2 wpd_a3)) bpd_a1) 0))
    (max (- (max wpd_a1 (max wpd_a2 wpd_a3)) bpd_a0) 0)
  )))
) :ruleset analysis)
