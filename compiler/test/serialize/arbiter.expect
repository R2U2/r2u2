STRUCT
	Request: {state: int; time_active: float;};
	Arbiter: {ReqSet: Request[];};
INPUT
	i0,i1,i2,i3: int;
	f0,f1,f2,f3: float;
DEFINE
	WAIT := 0;
	GRANT := 1;
	REJECT := 2;
	rq0 := Request(i0, f0);
	rq1 := Request(i1, f1);
	rq2 := Request(i2, f2);
	rq3 := Request(i3, f3);
	Arb0 := Arbiter({rq0, rq1});
	Arb1 := Arbiter({rq2, rq3});
	ArbSet := {Arb0, Arb1};
FTSPEC
	(((rq0.time_active - rq1.time_active) < 10.0) && ((rq1.time_active - rq0.time_active) < 10.0));
	foreach(arb : ArbSet)(foreach(rq : arb.ReqSet)(((rq.state == WAIT) U[0,5] ((rq.state == GRANT) || (rq.state == REJECT)))));
