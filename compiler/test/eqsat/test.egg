(sort IntervalSort)
(constructor Interval (i64 i64) IntervalSort)

(datatype MLTL
  (Bool bool)
  (Var String)
  (Not MLTL)
  (Implies MLTL MLTL)
  (Equiv MLTL MLTL)
  (And2 MLTL MLTL)
  (And3 MLTL MLTL MLTL)
  (And4 MLTL MLTL MLTL MLTL)
  (Or2 MLTL MLTL)
  (Or3 MLTL MLTL MLTL)
  (Or4 MLTL MLTL MLTL MLTL)
  (Global IntervalSort MLTL)
  (Future IntervalSort MLTL)
  (Until IntervalSort MLTL MLTL)
  (Release IntervalSort MLTL MLTL)
)

(ruleset const-folding)
(ruleset mltl-rewrites)(rewrite
  (Not (Bool true))
  (Bool false)
  :ruleset const-folding
)

(rewrite
  (Not (Bool false))
  (Bool true)
  :ruleset const-folding
)

(rewrite
  (And2 a0 (Bool false))
  (Bool false)
  :subsume
  :ruleset const-folding
)

(rewrite
  (Or2 a0 (Bool true))
  (Bool true)
  :subsume
  :ruleset const-folding
)

(rewrite
  (And2 a0 (Not a0))
  (Bool false)
  :ruleset const-folding
)

(rewrite
  (Or2 a0 (Not a0))
  (Bool true)
  :ruleset const-folding
)

(rewrite
  (Global (Interval b0 b1) (Bool false))
  (Bool false)
  :subsume
  :ruleset const-folding
)

(rewrite
  (Global (Interval b0 b1) (Bool true))
  (Bool true)
  :subsume
  :ruleset const-folding
)

(rewrite
  (Future (Interval b0 b1) (Bool false))
  (Bool false)
  :subsume
  :ruleset const-folding
)

(rewrite
  (Future (Interval b0 b1) (Bool true))
  (Bool true)
  :subsume
  :ruleset const-folding
)

(rewrite
  (Or2 (Future (Interval b0 b1) a0) (Global (Interval b0 b1) (Not a0)))
  (Bool true)
  :ruleset const-folding
)

(rewrite
  (And2 (Global (Interval b0 b1) (Not a0)) (Future (Interval b2 b3) a0))
  (Bool false)
  :when ((<= b0 b2) (<= b3 b1))
  :ruleset const-folding
)

(rewrite
  (And2 (Global (Interval b0 b1) a0) (Future (Interval b2 b3) (Not a0)))
  (Bool false)
  :when ((<= b0 b2) (<= b3 b1))
  :ruleset const-folding
)



