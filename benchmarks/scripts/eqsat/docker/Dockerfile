# Base: OS packages, locale, and Rust toolchain (shared by builder stages).
# ------------------------------------------------------------------------------
FROM ubuntu:24.04 AS base

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive

