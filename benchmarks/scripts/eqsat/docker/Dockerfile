    && rm -rf /var/lib/apt/lists/*

RUN sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && \
    locale-gen en_US.UTF-8

ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y

ENV PATH=/root/.cargo/bin:$PATH

# ------------------------------------------------------------------------------
# z3: prebuilt release binary.
# ------------------------------------------------------------------------------
FROM base AS z3

RUN mkdir -p /opt/z3 && \
    cd /opt/z3 && \
    wget -q https://github.com/Z3Prover/z3/releases/download/z3-4.15.0/z3-4.15.0-x64-glibc-2.39.zip && \
    unzip -q z3-4.15.0-x64-glibc-2.39.zip && \
    rm z3-4.15.0-x64-glibc-2.39.zip && \
    cp -r z3-4.15.0-x64-glibc-2.39/* . && \
    rm -rf z3-4.15.0-x64-glibc-2.39 && \
    chmod +x /opt/z3/bin/z3

# ------------------------------------------------------------------------------
# cvc5: prebuilt release binary.
# ------------------------------------------------------------------------------
FROM base AS cvc5

RUN cd /opt && \
    wget -q https://github.com/cvc5/cvc5/releases/download/cvc5-1.3.3/cvc5-Linux-x86_64-static.zip && \
    unzip -q cvc5-Linux-x86_64-static.zip && \
    rm cvc5-Linux-x86_64-static.zip && \
    mv cvc5-Linux-x86_64-static cvc5 && \
    chmod +x /opt/cvc5/bin/cvc5

# ------------------------------------------------------------------------------
# rust-tools: egglog and egglog-experimental (only patches copied from the repo).
# ------------------------------------------------------------------------------
FROM base AS rust-tools

COPY compiler/scripts/egglog.patch /tmp/egglog.patch
COPY compiler/scripts/egglog_experimental.patch /tmp/egglog_experimental.patch

RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/tmp/egglog-cargo-target \
    git clone https://github.com/egraphs-good/egglog.git /opt/egglog && \
    cd /opt/egglog && \
    git checkout v2.0.0 && \
    patch -p1 < /tmp/egglog.patch && \
    CARGO_TARGET_DIR=/tmp/egglog-cargo-target cargo build --bin egglog --release && \
    install -D /tmp/egglog-cargo-target/release/egglog /opt/egglog/target/release/egglog

RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/tmp/egglog-experimental-cargo-target \
    git clone https://github.com/egraphs-good/egglog-experimental.git /opt/egglog-experimental && \
    cd /opt/egglog-experimental && \
    git checkout 38b3898 && \
    patch -p1 < /tmp/egglog_experimental.patch && \
    CARGO_TARGET_DIR=/tmp/egglog-experimental-cargo-target cargo build --bin egglog-experimental --release && \
    install -D /tmp/egglog-experimental-cargo-target/release/egglog-experimental /opt/egglog-experimental/target/release/egglog-experimental

