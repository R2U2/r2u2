# This file was generated by Cursor AI on 2025-01-20.
Bootstrap: docker
From: ubuntu:24.04

%environment
    export PATH=/opt/z3/bin:$PATH
    export PATH=/opt/egglog/target/release:$PATH
    export PATH=/opt/egglog-experimental/target/release:$PATH
    export PATH=/root/.cargo/bin:$PATH
    export PATH=/opt/venv/bin:$PATH
    export PATH=/opt/r2u2/build:$PATH
    export VIRTUAL_ENV=/opt/venv
    export GRB_LICENSE_FILE=/root/gurobi.lic
    export PYTHONPATH=/opt/c2po:$PYTHONPATH
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8

%post
    # Install system dependencies
    apt-get update
    apt-get install -y \
        python3 \
        python3-pip \
        python3-venv \
        git \
        curl \
        wget \
        unzip \
        build-essential \
        ca-certificates \
        parallel \
        locales \
        patch \
        && rm -rf /var/lib/apt/lists/*
    
    # Configure locale to suppress Perl warnings
    sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen
    locale-gen en_US.UTF-8

    # Install Rust
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    export PATH="$HOME/.cargo/bin:$PATH"
    . "$HOME/.cargo/env"

    # Install z3
    mkdir -p /opt/z3
    cd /opt/z3
    wget https://github.com/Z3Prover/z3/releases/download/z3-4.15.0/z3-4.15.0-x64-glibc-2.39.zip
    unzip z3-4.15.0-x64-glibc-2.39.zip
    rm z3-4.15.0-x64-glibc-2.39.zip
    cp -r z3-4.15.0-x64-glibc-2.39/* .
    rm -rf z3-4.15.0-x64-glibc-2.39
    chmod +x bin/z3

    # Build egglog
    mkdir -p /opt/egglog
    cd /opt/egglog
    git clone https://github.com/egraphs-good/egglog.git .
    git checkout v2.0.0
    # Apply patch to egglog
    patch -p1 < /opt/egglog.patch
    cargo build --bin egglog --release

    # Build egglog-experimental
    mkdir -p /opt/egglog-experimental
    cd /opt/egglog-experimental
    git clone https://github.com/egraphs-good/egglog-experimental.git .
    git checkout 38b3898b2eea8efb901d0b3161931af44da0589c
    patch -p1 < /opt/egglog_experimental.patch
    cargo build --bin egglog-experimental --release

    # Create and activate Python virtual environment
    python3 -m venv /opt/venv
    . /opt/venv/bin/activate

    # Install gurobipy in virtual environment
    pip install gurobipy==12.0.3

    # Create directory for gurobi license
    mkdir -p /root
    # Note: License file should be bind-mounted to /root/gurobi.lic at runtime

    # Create directories for c2po and benchmark scripts
    mkdir -p /opt/c2po
    mkdir -p /opt/benchmark
    
    # Make benchmark scripts executable
    chmod +x /opt/benchmark/benchmark.sh

%files
    # Copy c2po.py and c2po package from compiler directory
    # Copy benchmark.sh and template files from current directory
    # Copy egglog patch file
    # Build should be run from benchmarks/scripts/eqsat/ directory
    ../../../compiler/c2po.py /opt/c2po/c2po.py
    ../../../compiler/c2po /opt/c2po/c2po
    ../../../compiler/scripts/egglog.patch /opt/egglog.patch
    ../../../compiler/scripts/egglog_experimental.patch /opt/egglog_experimental.patch
    benchmark.sh /opt/benchmark/benchmark.sh

%runscript
    #!/bin/sh
    # Activate virtual environment
    . /opt/venv/bin/activate
    exec bash /opt/benchmark/benchmark.sh "$@" --c2po-path /opt/c2po/c2po.py
