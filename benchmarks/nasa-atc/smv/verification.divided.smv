-- H-5
-- During a conflict, every agent that is responsible for an aircraft
-- involved in the conflict and that has detected the conflict,
-- must provide a resolution to the aircraft.
INVARSPEC NAME H-5-Near-ATC-INVAR :=
  ((ac_1_ts_sa_agent = SA_ATC & atc.ac_1_predicted_conflict_near) ->
     (atc.ac_1_suggestion_near != TRJ_NOP)) &
  ((ac_2_ts_sa_agent = SA_ATC & atc.ac_2_predicted_conflict_near) ->
     (atc.ac_2_suggestion_near != TRJ_NOP)) &
  ((ac_3_ts_sa_agent = SA_ATC & atc.ac_3_predicted_conflict_near) ->
     (atc.ac_3_suggestion_near != TRJ_NOP)) &
  ((ac_4_ts_sa_agent = SA_ATC & atc.ac_4_predicted_conflict_near) ->
     (atc.ac_4_suggestion_near != TRJ_NOP));

INVARSPEC NAME H-5-Mid-ATC-INVAR :=
  ((ac_1_ts_sa_agent = SA_ATC & atc.ac_1_predicted_conflict_mid) ->
     (atc.ac_1_suggestion_mid != TRJ_NOP)) &
  ((ac_2_ts_sa_agent = SA_ATC & atc.ac_2_predicted_conflict_mid) ->
     (atc.ac_2_suggestion_mid != TRJ_NOP)) &
  ((ac_3_ts_sa_agent = SA_ATC & atc.ac_3_predicted_conflict_mid) ->
     (atc.ac_3_suggestion_mid != TRJ_NOP)) &
  ((ac_4_ts_sa_agent = SA_ATC & atc.ac_4_predicted_conflict_mid) ->
     (atc.ac_4_suggestion_mid != TRJ_NOP));

INVARSPEC NAME H-5-Far-ATC-INVAR :=
  ((ac_1_ts_sa_agent = SA_ATC & atc.ac_1_predicted_conflict_far) ->
     (atc.ac_1_suggestion_far != TRJ_NOP)) &
  ((ac_2_ts_sa_agent = SA_ATC & atc.ac_2_predicted_conflict_far) ->
     (atc.ac_2_suggestion_far != TRJ_NOP)) &
  ((ac_3_ts_sa_agent = SA_ATC & atc.ac_3_predicted_conflict_far) ->
     (atc.ac_3_suggestion_far != TRJ_NOP)) &
  ((ac_4_ts_sa_agent = SA_ATC & atc.ac_4_predicted_conflict_far) ->
     (atc.ac_4_suggestion_far != TRJ_NOP));

INVARSPEC NAME H-5-Near-SELF-INVAR :=
  ((ac_1_ts_sa_agent = SA_SELF & ac_1.cdr.predicted_conflict_near) ->
       (ac_1.cdr.suggestion_near != TRJ_NOP)) &
  ((ac_2_ts_sa_agent = SA_SELF & ac_2.cdr.predicted_conflict_near) ->
       (ac_2.cdr.suggestion_near != TRJ_NOP)) &
  ((ac_3_ts_sa_agent = SA_SELF & ac_3.cdr.predicted_conflict_near) ->
       (ac_3.cdr.suggestion_near != TRJ_NOP)) &
  ((ac_4_ts_sa_agent = SA_SELF & ac_4.cdr.predicted_conflict_near) ->
       (ac_4.cdr.suggestion_near != TRJ_NOP));

INVARSPEC NAME H-5-Mid-SELF-INVAR :=
  ((ac_1_ts_sa_agent = SA_SELF & ac_1.cdr.predicted_conflict_mid) ->
       (ac_1.cdr.suggestion_mid != TRJ_NOP)) &
  ((ac_2_ts_sa_agent = SA_SELF & ac_2.cdr.predicted_conflict_mid) ->
       (ac_2.cdr.suggestion_mid != TRJ_NOP)) &
  ((ac_3_ts_sa_agent = SA_SELF & ac_3.cdr.predicted_conflict_mid) ->
       (ac_3.cdr.suggestion_mid != TRJ_NOP)) &
  ((ac_4_ts_sa_agent = SA_SELF & ac_4.cdr.predicted_conflict_mid) ->
       (ac_4.cdr.suggestion_mid != TRJ_NOP));

INVARSPEC NAME H-5-Far-SELF-INVAR :=
  ((ac_1_ts_sa_agent = SA_SELF & ac_1.cdr.predicted_conflict_far) ->
       (ac_1.cdr.suggestion_far != TRJ_NOP)) &
  ((ac_2_ts_sa_agent = SA_SELF & ac_2.cdr.predicted_conflict_far) ->
       (ac_2.cdr.suggestion_far != TRJ_NOP)) &
  ((ac_3_ts_sa_agent = SA_SELF & ac_3.cdr.predicted_conflict_far) ->
       (ac_3.cdr.suggestion_far != TRJ_NOP)) &
  ((ac_4_ts_sa_agent = SA_SELF & ac_4.cdr.predicted_conflict_far) ->
       (ac_4.cdr.suggestion_far != TRJ_NOP));

-- H-6 (By Construction)


-- S-4 GSEP
-- Every conflict involving at least one SSEP and one GSEP is
-- successfully resolved without issuing a resolution maneuver to the
-- GSEP(s).
INVARSPEC NAME S-4-GSEP-Near-INVAR :=
  --- AC_1 ATC : AC2 SELF, AC3 SELF, AC4 SELF
  ((ac_1_ts_sa_agent = SA_ATC & ac_2_ts_sa_agent = SA_SELF & communication_phase &
      ac_1.intention_near = ac_2.intention_near) ->
         (next(ac_1.intention_near) = ac_1.intention_near)) &
  ((ac_1_ts_sa_agent = SA_ATC & ac_3_ts_sa_agent = SA_SELF & communication_phase &
      ac_1.intention_near = ac_3.intention_near) ->
         (next(ac_1.intention_near) = ac_1.intention_near)) &
  ((ac_1_ts_sa_agent = SA_ATC & ac_4_ts_sa_agent = SA_SELF & communication_phase &
      ac_1.intention_near = ac_4.intention_near) ->
         (next(ac_1.intention_near) = ac_1.intention_near)) &
  --- AC_2 ATC : AC1 SELF, AC3 SELF, AC4 SELF
  ((ac_2_ts_sa_agent = SA_ATC & ac_1_ts_sa_agent = SA_SELF & communication_phase &
      ac_2.intention_near = ac_1.intention_near) ->
         (next(ac_2.intention_near) = ac_2.intention_near)) &
  ((ac_2_ts_sa_agent = SA_ATC & ac_3_ts_sa_agent = SA_SELF & communication_phase &
      ac_2.intention_near = ac_3.intention_near) ->
         (next(ac_2.intention_near) = ac_2.intention_near)) &
  ((ac_2_ts_sa_agent = SA_ATC & ac_4_ts_sa_agent = SA_SELF & communication_phase &
      ac_2.intention_near = ac_4.intention_near) ->
         (next(ac_2.intention_near) = ac_2.intention_near)) &
  --- AC_3 ATC : AC1 SELF, AC2 SELF, AC4 SELF
  ((ac_3_ts_sa_agent = SA_ATC & ac_1_ts_sa_agent = SA_SELF & communication_phase &
      ac_3.intention_near = ac_1.intention_near) ->
         (next(ac_3.intention_near) = ac_3.intention_near)) &
  ((ac_3_ts_sa_agent = SA_ATC & ac_2_ts_sa_agent = SA_SELF & communication_phase &
      ac_3.intention_near = ac_2.intention_near) ->
         (next(ac_3.intention_near) = ac_3.intention_near)) &
  ((ac_3_ts_sa_agent = SA_ATC & ac_4_ts_sa_agent = SA_SELF & communication_phase &
      ac_3.intention_near = ac_4.intention_near) ->
         (next(ac_3.intention_near) = ac_3.intention_near)) &
  --- AC_4 ATC : AC1 SELF, AC2 SELF, AC3 SELF
  ((ac_4_ts_sa_agent = SA_ATC & ac_1_ts_sa_agent = SA_SELF & communication_phase &
      ac_4.intention_near = ac_1.intention_near) ->
         (next(ac_4.intention_near) = ac_4.intention_near)) &
  ((ac_4_ts_sa_agent = SA_ATC & ac_2_ts_sa_agent = SA_SELF & communication_phase &
      ac_4.intention_near = ac_2.intention_near) ->
         (next(ac_4.intention_near) = ac_4.intention_near)) &
  ((ac_4_ts_sa_agent = SA_ATC & ac_3_ts_sa_agent = SA_SELF & communication_phase &
      ac_4.intention_near = ac_3.intention_near) ->
         (next(ac_4.intention_near) = ac_4.intention_near));

INVARSPEC NAME S-4-GSEP-Mid-INVAR :=
  --- AC_1 ATC : AC2 SELF, AC3 SELF, AC4 SELF
  ((ac_1_ts_sa_agent = SA_ATC & ac_2_ts_sa_agent = SA_SELF & communication_phase &
      ac_1.intention_mid = ac_2.intention_mid) ->
         (next(ac_1.intention_mid) = ac_1.intention_mid)) &
  ((ac_1_ts_sa_agent = SA_ATC & ac_3_ts_sa_agent = SA_SELF & communication_phase &
      ac_1.intention_mid = ac_3.intention_mid) ->
         (next(ac_1.intention_mid) = ac_1.intention_mid)) &
  ((ac_1_ts_sa_agent = SA_ATC & ac_4_ts_sa_agent = SA_SELF & communication_phase &
      ac_1.intention_mid = ac_4.intention_mid) ->
         (next(ac_1.intention_mid) = ac_1.intention_mid)) &
  --- AC_2 ATC : AC1 SELF, AC3 SELF, AC4 SELF
  ((ac_2_ts_sa_agent = SA_ATC & ac_1_ts_sa_agent = SA_SELF & communication_phase &
      ac_2.intention_mid = ac_1.intention_mid) ->
         (next(ac_2.intention_mid) = ac_2.intention_mid)) &
  ((ac_2_ts_sa_agent = SA_ATC & ac_3_ts_sa_agent = SA_SELF & communication_phase &
      ac_2.intention_mid = ac_3.intention_mid) ->
         (next(ac_2.intention_mid) = ac_2.intention_mid)) &
  ((ac_2_ts_sa_agent = SA_ATC & ac_4_ts_sa_agent = SA_SELF & communication_phase &
      ac_2.intention_mid = ac_4.intention_mid) ->
         (next(ac_2.intention_mid) = ac_2.intention_mid)) &
  --- AC_3 ATC : AC1 SELF, AC2 SELF, AC4 SELF
  ((ac_3_ts_sa_agent = SA_ATC & ac_1_ts_sa_agent = SA_SELF & communication_phase &
      ac_3.intention_mid = ac_1.intention_mid) ->
         (next(ac_3.intention_mid) = ac_3.intention_mid)) &
  ((ac_3_ts_sa_agent = SA_ATC & ac_2_ts_sa_agent = SA_SELF & communication_phase &
      ac_3.intention_mid = ac_2.intention_mid) ->
         (next(ac_3.intention_mid) = ac_3.intention_mid)) &
  ((ac_3_ts_sa_agent = SA_ATC & ac_4_ts_sa_agent = SA_SELF & communication_phase &
      ac_3.intention_mid = ac_4.intention_mid) ->
         (next(ac_3.intention_mid) = ac_3.intention_mid)) &
  --- AC_4 ATC : AC1 SELF, AC2 SELF, AC3 SELF
  ((ac_4_ts_sa_agent = SA_ATC & ac_1_ts_sa_agent = SA_SELF & communication_phase &
      ac_4.intention_mid = ac_1.intention_mid) ->
         (next(ac_4.intention_mid) = ac_4.intention_mid)) &
  ((ac_4_ts_sa_agent = SA_ATC & ac_2_ts_sa_agent = SA_SELF & communication_phase &
      ac_4.intention_mid = ac_2.intention_mid) ->
         (next(ac_4.intention_mid) = ac_4.intention_mid)) &
  ((ac_4_ts_sa_agent = SA_ATC & ac_3_ts_sa_agent = SA_SELF & communication_phase &
      ac_4.intention_mid = ac_3.intention_mid) ->
         (next(ac_4.intention_mid) = ac_4.intention_mid));

INVARSPEC NAME S-4-GSEP-Far-INVAR :=
  --- AC_1 ATC : AC2 SELF, AC3 SELF, AC4 SELF
  ((ac_1_ts_sa_agent = SA_ATC & ac_2_ts_sa_agent = SA_SELF & communication_phase &
