         (next(ac_1.intention_far) = ac_1.intention_far)) &
  ((ac_1_ts_sa_agent = SA_ATC & ac_3_ts_sa_agent = SA_SELF & communication_phase &
      ac_1.intention_far = ac_3.intention_far) ->
         (next(ac_1.intention_far) = ac_1.intention_far)) &
  ((ac_1_ts_sa_agent = SA_ATC & ac_4_ts_sa_agent = SA_SELF & communication_phase &
      ac_1.intention_far = ac_4.intention_far) ->
         (next(ac_1.intention_far) = ac_1.intention_far)) &
  --- AC_2 ATC : AC1 SELF, AC3 SELF, AC4 SELF
  ((ac_2_ts_sa_agent = SA_ATC & ac_1_ts_sa_agent = SA_SELF & communication_phase &
