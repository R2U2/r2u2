         (next(ac_2.intention_far) = ac_2.intention_far)) &
  --- AC_3 ATC : AC1 SELF, AC2 SELF, AC4 SELF
  ((ac_3_ts_sa_agent = SA_ATC & ac_1_ts_sa_agent = SA_SELF & communication_phase &
      ac_3.intention_far = ac_1.intention_far) ->
         (next(ac_3.intention_far) = ac_3.intention_far)) &
  ((ac_3_ts_sa_agent = SA_ATC & ac_2_ts_sa_agent = SA_SELF & communication_phase &
