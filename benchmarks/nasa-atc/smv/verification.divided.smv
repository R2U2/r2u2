#include "../oss/header.h"

--
-- Hard Constraint H-1
--
-- It is never possible to have a LOS.
INVARSPEC NAME NO-LOS-INVAR := ! LOS;

--
-- Soft Constraints (Safety-Critical)
--

-- It is never possible to have a predicted LOS in the Near-window.
INVARSPEC NAME NO-LOS-Near-INVAR := ! LOS_near;
-- It is never possible to have a predicted LOS in the Mid-window.
INVARSPEC NAME NO-LOS-Mid-INVAR := ! LOS_mid;
-- It is never possible to have a predicted LOS in the Far-window.
INVARSPEC NAME NO-LOS-Far-INVAR := ! LOS_far;

INVARSPEC NAME Detect-Near-INVAR :=
  -- Every conflict in the Near-window is detected by at least one
  -- Agent.
  ((ac_1.intention_near = ac_2.intention_near) ->
     (atc.ac_1_predicted_conflict_near | ac_1.predicted_conflict_near) &
     (atc.ac_2_predicted_conflict_near | ac_2.predicted_conflict_near)) &
  ((ac_1.intention_near = ac_3.intention_near) ->
     (atc.ac_1_predicted_conflict_near | ac_1.predicted_conflict_near) &
     (atc.ac_3_predicted_conflict_near | ac_3.predicted_conflict_near)) &
  ((ac_1.intention_near = ac_4.intention_near) ->
     (atc.ac_1_predicted_conflict_near | ac_1.predicted_conflict_near) &
     (atc.ac_4_predicted_conflict_near | ac_4.predicted_conflict_near)) &
  ((ac_2.intention_near = ac_3.intention_near) ->
     (atc.ac_2_predicted_conflict_near | ac_2.predicted_conflict_near) &
     (atc.ac_3_predicted_conflict_near | ac_3.predicted_conflict_near)) &
  ((ac_2.intention_near = ac_4.intention_near) ->
     (atc.ac_2_predicted_conflict_near | ac_2.predicted_conflict_near) &
     (atc.ac_4_predicted_conflict_near | ac_4.predicted_conflict_near)) &
  ((ac_3.intention_near = ac_4.intention_near) ->
     (atc.ac_3_predicted_conflict_near | ac_3.predicted_conflict_near) &
     (atc.ac_4_predicted_conflict_near | ac_4.predicted_conflict_near));

INVARSPEC NAME Detect-Mid-INVAR :=
  ((ac_1.intention_mid = ac_2.intention_mid) ->
     (atc.ac_1_predicted_conflict_mid | ac_1.predicted_conflict_mid) &
     (atc.ac_2_predicted_conflict_mid | ac_2.predicted_conflict_mid)) &
  ((ac_1.intention_mid = ac_3.intention_mid) ->
     (atc.ac_1_predicted_conflict_mid | ac_1.predicted_conflict_mid) &
     (atc.ac_3_predicted_conflict_mid | ac_3.predicted_conflict_mid)) &
  ((ac_1.intention_mid = ac_4.intention_mid) ->
     (atc.ac_1_predicted_conflict_mid | ac_1.predicted_conflict_mid) &
     (atc.ac_4_predicted_conflict_mid | ac_4.predicted_conflict_mid)) &
  ((ac_2.intention_mid = ac_3.intention_mid) ->
     (atc.ac_2_predicted_conflict_mid | ac_2.predicted_conflict_mid) &
     (atc.ac_3_predicted_conflict_mid | ac_3.predicted_conflict_mid)) &
  ((ac_2.intention_mid = ac_4.intention_mid) ->
     (atc.ac_2_predicted_conflict_mid | ac_2.predicted_conflict_mid) &
     (atc.ac_4_predicted_conflict_mid | ac_4.predicted_conflict_mid)) &
  ((ac_3.intention_mid = ac_4.intention_mid) ->
     (atc.ac_3_predicted_conflict_mid | ac_3.predicted_conflict_mid) &
     (atc.ac_4_predicted_conflict_mid | ac_4.predicted_conflict_mid));

INVARSPEC NAME Detect-Far-INVAR :=
  ((ac_1.intention_far = ac_2.intention_far) ->
     (atc.ac_1_predicted_conflict_far | ac_1.predicted_conflict_far) &
     (atc.ac_2_predicted_conflict_far | ac_2.predicted_conflict_far)) &
  ((ac_1.intention_far = ac_3.intention_far) ->
     (atc.ac_1_predicted_conflict_far | ac_1.predicted_conflict_far) &
     (atc.ac_3_predicted_conflict_far | ac_3.predicted_conflict_far)) &
  ((ac_1.intention_far = ac_4.intention_far) ->
     (atc.ac_1_predicted_conflict_far | ac_1.predicted_conflict_far) &
     (atc.ac_4_predicted_conflict_far | ac_4.predicted_conflict_far)) &
  ((ac_2.intention_far = ac_3.intention_far) ->
     (atc.ac_2_predicted_conflict_far | ac_2.predicted_conflict_far) &
     (atc.ac_3_predicted_conflict_far | ac_3.predicted_conflict_far)) &
  ((ac_2.intention_far = ac_4.intention_far) ->
     (atc.ac_2_predicted_conflict_far | ac_2.predicted_conflict_far) &
     (atc.ac_4_predicted_conflict_far | ac_4.predicted_conflict_far)) &
  ((ac_3.intention_far = ac_4.intention_far) ->
     (atc.ac_3_predicted_conflict_far | ac_3.predicted_conflict_far) &
     (atc.ac_4_predicted_conflict_far | ac_4.predicted_conflict_far));

INVARSPEC NAME New-Conflict-Near-INVAR :=
  -- Resolving a conflict in the Near-window cannot lead to a new LOS.
  maneuvering_phase -> ((Count_LOS_Near = 0) | next(Count_LOS) < Count_LOS_Near);

INVARSPEC NAME New-Conflict-Mid-INVAR :=
  -- Resolving a conflict in the Mid-window cannot lead to a new LOS_Near
  maneuvering_phase -> ((Count_LOS_Mid = 0) | next(Count_LOS_Near) < Count_LOS_Mid);

INVARSPEC NAME New-Conflict-Far-INVAR :=
  -- Resolving a conflict in the Near-window cannot lead to a new LOS_Mid
  maneuvering_phase -> ((Count_LOS_Far = 0) | next(Count_LOS_Mid) < Count_LOS_Far);


INVARSPEC NAME Fast-Resolve-Near-INVAR :=
  -- Every conflict in the Near-window must be resolved in the
  -- Near-window.
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_near = ac_2.intention_near) ->
          (next(ac_1.intention_near) != next(ac_2.intention_near))) &
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_near = ac_3.intention_near) ->
          (next(ac_1.intention_near) != next(ac_3.intention_near))) &
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_near = ac_4.intention_near) ->
          (next(ac_1.intention_near) != next(ac_4.intention_near))) &
  ((communication_phase & next(maneuvering_phase) & ac_2.intention_near = ac_3.intention_near) ->
          (next(ac_2.intention_near) != next(ac_3.intention_near))) &
  ((communication_phase & next(maneuvering_phase) & ac_2.intention_near = ac_4.intention_near) ->
          (next(ac_2.intention_near) != next(ac_4.intention_near))) &
  ((communication_phase & next(maneuvering_phase) & ac_3.intention_near = ac_4.intention_near) ->
          (next(ac_3.intention_near) != next(ac_4.intention_near)));

INVARSPEC NAME Fast-Resolve-Mid-INVAR :=
  -- Every conflict in the Mid-window must be resolved in the
  -- Mid-window.
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_mid = ac_2.intention_mid) ->
          (next(ac_1.intention_mid) != next(ac_2.intention_mid))) &
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_mid = ac_3.intention_mid) ->
          (next(ac_1.intention_mid) != next(ac_3.intention_mid))) &
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_mid = ac_4.intention_mid) ->
          (next(ac_1.intention_mid) != next(ac_4.intention_mid))) &
  ((communication_phase & next(maneuvering_phase) & ac_2.intention_mid = ac_3.intention_mid) ->
          (next(ac_2.intention_mid) != next(ac_3.intention_mid))) &
  ((communication_phase & next(maneuvering_phase) & ac_2.intention_mid = ac_4.intention_mid) ->
          (next(ac_2.intention_mid) != next(ac_4.intention_mid))) &
  ((communication_phase & next(maneuvering_phase) & ac_3.intention_mid = ac_4.intention_mid) ->
          (next(ac_3.intention_mid) != next(ac_4.intention_mid)));

INVARSPEC NAME Fast-Resolve-Far-INVAR :=
  -- Every conflict in the Mid-window must be resolved in the
  -- Mid-window.
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_far = ac_2.intention_far) ->
          (next(ac_1.intention_far) != next(ac_2.intention_far))) &
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_far = ac_3.intention_far) ->
          (next(ac_1.intention_far) != next(ac_3.intention_far))) &
  ((communication_phase & next(maneuvering_phase) & ac_1.intention_far = ac_4.intention_far) ->
          (next(ac_1.intention_far) != next(ac_4.intention_far))) &
  ((communication_phase & next(maneuvering_phase) & ac_2.intention_far = ac_3.intention_far) ->
          (next(ac_2.intention_far) != next(ac_3.intention_far))) &
  ((communication_phase & next(maneuvering_phase) & ac_2.intention_far = ac_4.intention_far) ->
          (next(ac_2.intention_far) != next(ac_4.intention_far))) &
  ((communication_phase & next(maneuvering_phase) & ac_3.intention_far = ac_4.intention_far) ->
          (next(ac_3.intention_far) != next(ac_4.intention_far)));


--
-- Interesting Properties
--

-- H-3
-- The information available to the ATC must be consistent with the
-- actual state of the airspace: trajectory intention, which aircrafts
-- are GSEPs and which are SSEPs.
INVARSPEC NAME H-3-Near-INVAR:=
  ((ac_1_atc_info_level > INFO_LEVEL_NEAR) -> (atc_ac_1_intention_near = ac_1.intention_near)) &
  ((ac_2_atc_info_level > INFO_LEVEL_NEAR) -> (atc_ac_2_intention_near = ac_2.intention_near)) &
  ((ac_3_atc_info_level > INFO_LEVEL_NEAR) -> (atc_ac_3_intention_near = ac_3.intention_near)) &
  ((ac_4_atc_info_level > INFO_LEVEL_NEAR) -> (atc_ac_4_intention_near = ac_4.intention_near));

INVARSPEC NAME H-3-Mid-INVAR:=
  ((ac_1_atc_info_level > INFO_LEVEL_MID) -> (atc_ac_1_intention_mid = ac_1.intention_mid)) &
  ((ac_2_atc_info_level > INFO_LEVEL_MID) -> (atc_ac_2_intention_mid = ac_2.intention_mid)) &
  ((ac_3_atc_info_level > INFO_LEVEL_MID) -> (atc_ac_3_intention_mid = ac_3.intention_mid)) &
  ((ac_4_atc_info_level > INFO_LEVEL_MID) -> (atc_ac_4_intention_mid = ac_4.intention_mid));

INVARSPEC NAME H-3-Far-INVAR:=
  ((ac_1_atc_info_level > INFO_LEVEL_FAR) -> (atc_ac_1_intention_far = ac_1.intention_far)) &
  ((ac_2_atc_info_level > INFO_LEVEL_FAR) -> (atc_ac_2_intention_far = ac_2.intention_far)) &
  ((ac_3_atc_info_level > INFO_LEVEL_FAR) -> (atc_ac_3_intention_far = ac_3.intention_far)) &
  ((ac_4_atc_info_level > INFO_LEVEL_FAR) -> (atc_ac_4_intention_far = ac_4.intention_far));

INVARSPEC NAME H-3-TS-SA-INVAR :=
  ac_1_ts_sa_agent = atc_ac_1_ts_sa_agent &
  ac_2_ts_sa_agent = atc_ac_2_ts_sa_agent &
  ac_3_ts_sa_agent = atc_ac_3_ts_sa_agent &
  ac_4_ts_sa_agent = atc_ac_4_ts_sa_agent;

INVARSPEC NAME H-3-SS-SA-INVAR :=
  ac_1_ss_sa_agent = atc_ac_1_ss_sa_agent &
  ac_2_ss_sa_agent = atc_ac_2_ss_sa_agent &
  ac_3_ss_sa_agent = atc_ac_3_ss_sa_agent &
  ac_4_ss_sa_agent = atc_ac_4_ss_sa_agent;

-- H-4
-- The application of the resolutions by an aircraft would lead it
-- to the state expected by the SA agent that sent the resolution.
LTLSPEC NAME H-4-Near-ATC-AC1-LTL :=
  -- Near-Window with ATC in charge
  -- AC 1
  G ((communication_phase & ac_1_ts_sa_agent = SA_ATC & atc.ac_1_suggestion_near = 1) ->
      F (maneuvering_phase -> X ac_1.intention_current = 1)) &
  G ((communication_phase & ac_1_ts_sa_agent = SA_ATC & atc.ac_1_suggestion_near = 2) ->
      F (maneuvering_phase -> X ac_1.intention_current = 2)) &
  G ((communication_phase & ac_1_ts_sa_agent = SA_ATC & atc.ac_1_suggestion_near = 3) ->
      F (maneuvering_phase -> X ac_1.intention_current = 3)) &
  G ((communication_phase & ac_1_ts_sa_agent = SA_ATC & atc.ac_1_suggestion_near = 4) ->
      F (maneuvering_phase -> X ac_1.intention_current = 4));

