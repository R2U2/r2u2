  G ((communication_phase & ac_1_is_ssep_ss & X maneuvering_phase) -> (
       (ac_1.cdr.suggestion_far = 1  -> X X ac_1.intention_mid = 1) &
       (ac_1.cdr.suggestion_far = 2  -> X X ac_1.intention_mid = 2) &
       (ac_1.cdr.suggestion_far = 3  -> X X ac_1.intention_mid = 3) &
       (ac_1.cdr.suggestion_far = 4  -> X X ac_1.intention_mid = 4)
    ));

