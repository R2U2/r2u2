         (next(ac_2.intention_far) = ac_2.intention_far)) &
  ((ac_2_is_ssep_ss & ac_4_is_gsep_ss & communication_phase &
      ac_2.intention_far = ac_4.intention_far) ->
         (next(ac_2.intention_far) = ac_2.intention_far)) &
  --- AC_3 ATC : AC1 SELF, AC2 SELF, AC4 SELF
  ((ac_3_is_ssep_ss & ac_1_is_gsep_ss & communication_phase &
      ac_3.intention_far = ac_1.intention_far) ->
         (next(ac_3.intention_far) = ac_3.intention_far)) &
  ((ac_3_is_ssep_ss & ac_2_is_gsep_ss & communication_phase &
      ac_3.intention_far = ac_2.intention_far) ->
         (next(ac_3.intention_far) = ac_3.intention_far)) &
  ((ac_3_is_ssep_ss & ac_4_is_gsep_ss & communication_phase &
      ac_3.intention_far = ac_4.intention_far) ->
         (next(ac_3.intention_far) = ac_3.intention_far)) &
  --- AC_4 ATC : AC1 SELF, AC2 SELF, AC3 SELF
  ((ac_4_is_ssep_ss & ac_1_is_gsep_ss & communication_phase &
      ac_4.intention_far = ac_1.intention_far) ->
         (next(ac_4.intention_far) = ac_4.intention_far)) &
  ((ac_4_is_ssep_ss & ac_2_is_gsep_ss & communication_phase &
      ac_4.intention_far = ac_2.intention_far) ->
         (next(ac_4.intention_far) = ac_4.intention_far)) &
  ((ac_4_is_ssep_ss & ac_3_is_gsep_ss & communication_phase &
      ac_4.intention_far = ac_3.intention_far) ->
         (next(ac_4.intention_far) = ac_4.intention_far));





--
-- MONITORS FOR PROPERTIES
--

-- Maneuvering Phase
DEFINE maneuvering_phase := ! communication_phase;

DEFINE Count_LOS := count(ac_1.intention_current = ac_2.intention_current, ac_1.intention_current = ac_3.intention_current, ac_1.intention_current = ac_4.intention_current) +
                    count(ac_2.intention_current = ac_3.intention_current, ac_2.intention_current = ac_4.intention_current) +
                    count(ac_3.intention_current = ac_4.intention_current);

DEFINE Count_LOS_Near := count(ac_1.intention_near = ac_2.intention_near, ac_1.intention_near = ac_3.intention_near, ac_1.intention_near = ac_4.intention_near) +
                         count(ac_2.intention_near = ac_3.intention_near, ac_2.intention_near = ac_4.intention_near) +
                         count(ac_3.intention_near = ac_4.intention_near);

DEFINE Count_LOS_Mid := count(ac_1.intention_mid = ac_2.intention_mid, ac_1.intention_mid = ac_3.intention_mid, ac_1.intention_mid = ac_4.intention_mid) +
                        count(ac_2.intention_mid = ac_3.intention_mid, ac_2.intention_mid = ac_4.intention_mid) +
                        count(ac_3.intention_mid = ac_4.intention_mid);

DEFINE Count_LOS_Far := count(ac_1.intention_far = ac_2.intention_far, ac_1.intention_far = ac_3.intention_far, ac_1.intention_far = ac_4.intention_far) +
                        count(ac_2.intention_far = ac_3.intention_far, ac_2.intention_far = ac_4.intention_far) +
                        count(ac_3.intention_far = ac_4.intention_far);

-- ATC Predicted conflict information
DEFINE
  atc.ac_1_predicted_conflict_near := atc.gcdr.ac_1_predicted_conflict_near;
  atc.ac_2_predicted_conflict_near := atc.gcdr.ac_2_predicted_conflict_near;
  atc.ac_3_predicted_conflict_near := atc.gcdr.ac_3_predicted_conflict_near;
  atc.ac_4_predicted_conflict_near := atc.gcdr.ac_4_predicted_conflict_near;

  atc.ac_1_predicted_conflict_mid := atc.gcdr.ac_1_predicted_conflict_mid;
  atc.ac_2_predicted_conflict_mid := atc.gcdr.ac_2_predicted_conflict_mid;
  atc.ac_3_predicted_conflict_mid := atc.gcdr.ac_3_predicted_conflict_mid;
  atc.ac_4_predicted_conflict_mid := atc.gcdr.ac_4_predicted_conflict_mid;

  atc.ac_1_predicted_conflict_far := atc.gcdr.ac_1_predicted_conflict_far;
  atc.ac_2_predicted_conflict_far := atc.gcdr.ac_2_predicted_conflict_far;
  atc.ac_3_predicted_conflict_far := atc.gcdr.ac_3_predicted_conflict_far;
  atc.ac_4_predicted_conflict_far := atc.gcdr.ac_4_predicted_conflict_far;

-- ATC Info Level
DEFINE
  ac_1_atc_info_level := com.input_ac_1_atc_info_level;
  ac_2_atc_info_level := com.input_ac_2_atc_info_level;
  ac_3_atc_info_level := com.input_ac_3_atc_info_level;
  ac_4_atc_info_level := com.input_ac_4_atc_info_level;

-- ATC-AC Intentions
DEFINE
  atc_ac_1_intention_near := atc.gcdr.input_ac_1_intention_near;
  atc_ac_1_intention_mid := atc.gcdr.input_ac_1_intention_mid;
  atc_ac_1_intention_far := atc.gcdr.input_ac_1_intention_far;

  atc_ac_2_intention_near := atc.gcdr.input_ac_2_intention_near;
  atc_ac_2_intention_mid := atc.gcdr.input_ac_2_intention_mid;
  atc_ac_2_intention_far := atc.gcdr.input_ac_2_intention_far;

  atc_ac_3_intention_near := atc.gcdr.input_ac_3_intention_near;
  atc_ac_3_intention_mid := atc.gcdr.input_ac_3_intention_mid;
  atc_ac_3_intention_far := atc.gcdr.input_ac_3_intention_far;

  atc_ac_4_intention_near := atc.gcdr.input_ac_4_intention_near;
  atc_ac_4_intention_mid := atc.gcdr.input_ac_4_intention_mid;
  atc_ac_4_intention_far := atc.gcdr.input_ac_4_intention_far;

-- ATC SA
DEFINE
  atc_ac_1_ts_sa_agent := atc.gcdr.input_ac_1_ts_sa_agent;
  atc_ac_1_ss_sa_agent := atc.gcdr.input_ac_1_ss_sa_agent;
  atc_ac_2_ts_sa_agent := atc.gcdr.input_ac_2_ts_sa_agent;
  atc_ac_2_ss_sa_agent := atc.gcdr.input_ac_2_ss_sa_agent;
  atc_ac_3_ts_sa_agent := atc.gcdr.input_ac_3_ts_sa_agent;
  atc_ac_3_ss_sa_agent := atc.gcdr.input_ac_3_ss_sa_agent;
  atc_ac_4_ts_sa_agent := atc.gcdr.input_ac_4_ts_sa_agent;
  atc_ac_4_ss_sa_agent := atc.gcdr.input_ac_4_ss_sa_agent;

DEFINE
   ac_1_is_ssep_ts := ac_1_ts_sa_agent = SA_SELF | (ac_1_ts_sa_agent = SA_SATC & ac_1.request_ts_sa_ground = FALSE);
   ac_2_is_ssep_ts := ac_2_ts_sa_agent = SA_SELF | (ac_2_ts_sa_agent = SA_SATC & ac_2.request_ts_sa_ground = FALSE);
   ac_3_is_ssep_ts := ac_3_ts_sa_agent = SA_SELF | (ac_3_ts_sa_agent = SA_SATC & ac_3.request_ts_sa_ground = FALSE);
   ac_4_is_ssep_ts := ac_4_ts_sa_agent = SA_SELF | (ac_4_ts_sa_agent = SA_SATC & ac_4.request_ts_sa_ground = FALSE);

   ac_1_is_ssep_ss := ac_1_ss_sa_agent = SA_SELF | (ac_1_ss_sa_agent = SA_SATC & ac_1.request_ss_sa_ground = FALSE);
   ac_2_is_ssep_ss := ac_2_ss_sa_agent = SA_SELF | (ac_2_ss_sa_agent = SA_SATC & ac_2.request_ss_sa_ground = FALSE);
   ac_3_is_ssep_ss := ac_3_ss_sa_agent = SA_SELF | (ac_3_ss_sa_agent = SA_SATC & ac_3.request_ss_sa_ground = FALSE);
   ac_4_is_ssep_ss := ac_4_ss_sa_agent = SA_SELF | (ac_4_ss_sa_agent = SA_SATC & ac_4.request_ss_sa_ground = FALSE);

   ac_1_is_gsep_ts := ac_1_ts_sa_agent = SA_ATC | ( ac_1_ts_sa_agent = SA_ATC & ac_1.request_ts_sa_ground = TRUE);
   ac_2_is_gsep_ts := ac_2_ts_sa_agent = SA_ATC | ( ac_2_ts_sa_agent = SA_ATC & ac_2.request_ts_sa_ground = TRUE);
   ac_3_is_gsep_ts := ac_3_ts_sa_agent = SA_ATC | ( ac_3_ts_sa_agent = SA_ATC & ac_3.request_ts_sa_ground = TRUE);
   ac_4_is_gsep_ts := ac_4_ts_sa_agent = SA_ATC | ( ac_4_ts_sa_agent = SA_ATC & ac_4.request_ts_sa_ground = TRUE);

   ac_1_is_gsep_ss := ac_1_ss_sa_agent = SA_ATC | ( ac_1_ss_sa_agent = SA_ATC & ac_1.request_ss_sa_ground = TRUE);
   ac_2_is_gsep_ss := ac_2_ss_sa_agent = SA_ATC | ( ac_2_ss_sa_agent = SA_ATC & ac_2.request_ss_sa_ground = TRUE);
   ac_3_is_gsep_ss := ac_3_ss_sa_agent = SA_ATC | ( ac_3_ss_sa_agent = SA_ATC & ac_3.request_ss_sa_ground = TRUE);
   ac_4_is_gsep_ss := ac_4_ss_sa_agent = SA_ATC | ( ac_4_ss_sa_agent = SA_ATC & ac_4.request_ss_sa_ground = TRUE);

