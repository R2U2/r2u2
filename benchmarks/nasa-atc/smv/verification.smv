-- Resolve (Was H-5)
-- During a conflict, every agent that is responsible for an aircraft
-- involved in the conflict and that has detected the conflict,
-- must provide a resolution to the aircraft.
INVARSPEC NAME Resolve-Near-ATC-INVAR :=
  ((ac_1_is_gsep_ts & atc.ac_1_predicted_conflict_near & communication_phase) ->
     (atc.ac_1_suggestion_near != TRJ_NOP)) &
  ((ac_2_is_gsep_ts & atc.ac_2_predicted_conflict_near & communication_phase) ->
     (atc.ac_2_suggestion_near != TRJ_NOP)) &
  ((ac_3_is_gsep_ts & atc.ac_3_predicted_conflict_near & communication_phase) ->
     (atc.ac_3_suggestion_near != TRJ_NOP)) &
  ((ac_4_is_gsep_ts & atc.ac_4_predicted_conflict_near & communication_phase) ->
     (atc.ac_4_suggestion_near != TRJ_NOP));

INVARSPEC NAME Resolve-Mid-ATC-INVAR :=
  ((ac_1_is_gsep_ts & atc.ac_1_predicted_conflict_mid & communication_phase) ->
     (atc.ac_1_suggestion_mid != TRJ_NOP)) &
  ((ac_2_is_gsep_ts & atc.ac_2_predicted_conflict_mid & communication_phase) ->
