  -- AC 2
  G ((communication_phase & ac_2_is_ssep_ss & X maneuvering_phase) -> (
       (ac_2.cdr.suggestion_far = 1  -> X X ac_2.intention_mid = 1) &
       (ac_2.cdr.suggestion_far = 2  -> X X ac_2.intention_mid = 2) &
       (ac_2.cdr.suggestion_far = 3  -> X X ac_2.intention_mid = 3) &
